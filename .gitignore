# ==========================================
# Persephone (.gitignore)
# Comprehensive VCS Git Ignore Rules
# ==========================================

# ------------------------------------------
# Persephone VCS Database & Temporary Repos
# ------------------------------------------
# Ignore the custom .purr database directory globally (created by purr init)
.purr/
**/.purr/

# Ignore any local test repositories or playground environments
test-repo/
test-home/
test-*/
playground-*/
temp-repo*/

# ------------------------------------------
# Go-Specific Rules
# ------------------------------------------
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Compiled purr binaries at any location
purr
/purr
/purr.exe
**/purr

# Go module/toolchain/build caches
.gocache/
.gomodcache/
.gopath/
.home/

# Test binaries and execution artifacts
*.test
*.out
coverage.*
*.coverprofile
profile.cov
*.prof
*.test.log

# Go workspace and lock files
go.work
go.work.sum

# Dependency directories (prefer go.sum/mod for dependency tracking)
vendor/

# ------------------------------------------
# AI Agents & Scratchpad Files
# ------------------------------------------
# Avoid uploading model / agent scratchpads and workspace temp configs
.antigravitycli
.antigravity/
.gemini/
.anthropic/
.cursor/
.copilot/
scratch/
**/scratch/
TUTOR.md
walkthrough.md
task.md
implementation_plan.md

# ------------------------------------------
# Environment & Secrets
# ------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ------------------------------------------
# IDEs & Editor Configuration
# ------------------------------------------
# VS Code
.vscode/
*.code-workspace

# JetBrains (GoLand, IntelliJ)
.idea/

# Eclipse
.metadata/
.project
.classpath
.settings/

# Vim / Emacs swap and backup files
*~
*.swp
*.swo
.viminfo
\#*\#
.\#*

# ------------------------------------------
# Operating System & System Cache
# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.Spotlight-V100
.Trashes
VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------------------------------
# Temporary & Log files
# ------------------------------------------
*.log
logs/
log/
tmp/
temp/
